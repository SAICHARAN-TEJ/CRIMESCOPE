# ── LLM (OpenRouter) ──────────────────────────────────────────────────
LLM_API_KEY=sk-or-v1-your-openrouter-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=deepseek/deepseek-v3:free
REASONING_MODEL_NAME=deepseek/deepseek-r1:free
FAST_MODEL_NAME=meta-llama/llama-3.3-70b:free
VISION_MODEL_NAME=google/gemini-2.5-pro:free

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/crimescope_password

# ── ChromaDB ──────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chroma

# ── Simulation ────────────────────────────────────────────────────────
SWARM_AGENT_COUNT=1000
SIMULATION_ROUNDS=30

# ── Rate Limiting ─────────────────────────────────────────────────────
OPENROUTER_RATE_LIMIT_RPM=20
OPENROUTER_ROTATE_MODELS=true

# ── App ───────────────────────────────────────────────────────────────
BACKEND_PORT=5001
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
