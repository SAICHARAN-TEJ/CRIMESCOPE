# ═══════════════════════════════════════════════════════════════════════
# CrimeScope v2.0 — Environment Configuration
# Copy to .env and fill in values. All settings have fallback defaults.
# ═══════════════════════════════════════════════════════════════════════

# ── Swarm Agent LLM (OpenRouter — single key for ALL calls) ────────
LLM_API_KEY=your_openrouter_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=deepseek/deepseek-v3:free
REASONING_MODEL_NAME=deepseek/deepseek-r1:free
FAST_MODEL_NAME=meta-llama/llama-3.3-70b:free
SYNTHESIS_MODEL_NAME=google/gemini-2.5-flash-preview:thinking

# ── Multimodal Vision ──────────────────────────────────────────────
VISION_MODEL_NAME=google/gemini-2.5-pro:free

# ── Agent Memory (mem0 — self-hosted) ──────────────────────────────
MEM0_STORAGE_PATH=./data/mem0

# ── Graph Database (Neo4j Community) ───────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/crimescope_password

# ── Vector Store (ChromaDB) ────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chroma

# ── Redis (Cache + Pub/Sub + Rate Limiting) ────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PostgreSQL (standalone — alternative to Supabase) ──────────────
# DATABASE_URL=postgresql://crimescope:crimescope_dev@postgres:5432/crimescope
# POSTGRES_PASSWORD=crimescope_dev

# ── Simulation Parameters ──────────────────────────────────────────
SWARM_AGENT_COUNT=1000
SIMULATION_ROUNDS=30
MAX_IMAGES_MODE1=6
MAX_DOCUMENTS_MODE2=3
MAX_VIDEOS_MODE2=2

# ── Agent Pipeline ─────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=60

# ── Audio Transcription (Whisper) ──────────────────────────────────
WHISPER_MODEL_SIZE=base

# ── Rate Limiting ──────────────────────────────────────────────────
OPENROUTER_RATE_LIMIT_RPM=20
OPENROUTER_ROTATE_MODELS=true

# ── Supabase (optional — demo mode if unset) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ────────────────────────────────────────────────────────────
BACKEND_PORT=5001
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:80
